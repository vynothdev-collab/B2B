# ─── Python / FastAPI Backend Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.

APP_NAME=B2B API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000

CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/b2b_db

SECRET_KEY=change-this-secret-key-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://localhost:6379/0

# Coresignal
CORESIGNAL_API_KEY=your_coresignal_api_key_here
CORESIGNAL_BASE_URL=https://api.coresignal.com/cdapi
CORESIGNAL_PAGE_SIZE=10
