# =============================================================================
# BACKEND — Python / FastAPI
# =============================================================================

# Byte-compiled / cache
backend/__pycache__/
backend/**/__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
backend/.venv/
backend/venv/
backend/env/
backend/ENV/
.venv/
venv/
env/

# Distribution / packaging
backend/*.egg-info/
backend/dist/
backend/build/
backend/.eggs/
*.egg

# Pytest / Coverage
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage
backend/coverage.xml
backend/.tox/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# MyPy
backend/.mypy_cache/
.mypy_cache/

# Ruff / Linting
backend/.ruff_cache/
.ruff_cache/

# Database files
backend/*.db
backend/*.sqlite3
*.db
*.sqlite3

# Alembic versions (keep migrations, ignore local override)
# backend/alembic/versions/  ← keep this tracked

# Celery
backend/celerybeat-schedule
backend/celerybeat.pid

# Uploads / media
backend/uploads/
backend/media/

